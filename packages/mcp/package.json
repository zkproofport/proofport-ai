    "privacy",
    "identity",
    "coinbase-kyc",
    "google-oidc",
    "x402",
    "erc-8004",
    "noir-lang",
    "base-chain",
    "tee",
    "nitro-enclaves"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "zkproofport-mcp": "dist/index.js",
    "zkproofport-prove": "dist/prove.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run"
  },
  "dependencies": {
