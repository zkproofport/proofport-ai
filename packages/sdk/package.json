{
  "name": "@zkproofport-ai/sdk",
  "version": "0.2.6",
  "description": "TypeScript SDK for AI agents to generate zero-knowledge proofs of identity (Coinbase KYC, Country, Google OIDC, Workspace, MS 365) via ZKProofport. x402 USDC payments on Base, ERC-8004 agent identity. Privacy-preserving authentication for autonomous agents.",
  "keywords": [
    "sdk",
    "typescript",
    "zero-knowledge-proofs",
    "zk-proofs",
    "zkp",
    "ai-agents",
    "privacy",
    "identity",
    "coinbase-kyc",
    "google-oidc",
    "x402",
    "erc-8004",
    "noir-lang",
    "base-chain",
    "ethers"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ethers": "^6.13.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zkproofport/proofport-ai",
    "directory": "packages/sdk"
  }
}
